---
import Layout from "../layouts/Layout.astro";
import { RUTINA, DIA_COLORS, TECNICA_LABELS, TECNICA_COLORS, type DiaCode } from "../data/routine";
import AuthGuard from "../components/AuthGuard";
import ExerciseTracker from "../components/ExerciseTracker";

const diaParam = (Astro.url.searchParams.get("dia") || "L") as DiaCode;
const diaActivo = RUTINA.find((d) => d.code === diaParam) ?? RUTINA[0];
---
<Layout title="Entreno · RACSO Stronger" active="entreno">
  <AuthGuard client:load>
    <header class="mb-4">
      <h1 class="text-lg font-medium">Entreno</h1>
      <p class="text-xs text-[var(--color-text-muted)]">
        Selecciona el día. Pesos y notas se autoguardan.
      </p>
    </header>

    <div class="mb-5 grid grid-cols-5 gap-1.5">
      {RUTINA.map((d) => (
        <a
          href={`/entreno?dia=${d.code}`}
          class:list={[
            "flex flex-col items-center justify-center rounded-lg border py-2 text-xs font-bold transition-colors",
            d.code === diaActivo.code
              ? `${DIA_COLORS[d.code].bg} border-transparent text-white`
              : "border-[var(--color-border)] bg-[var(--color-surface-2)] text-[var(--color-text-muted)]",
          ]}
        >
          <span class="text-base">{d.code}</span>
          <span class="text-[10px] font-medium opacity-80">{d.nombre.slice(0, 3)}</span>
        </a>
      ))}
    </div>

    <section class="mb-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-2)] p-4">
      <div class={`inline-flex rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase ${DIA_COLORS[diaActivo.code].chip}`}>
        Día {diaActivo.code} · {diaActivo.nombre}
      </div>
      <h2 class="mt-2 text-base font-medium leading-tight">{diaActivo.titulo}</h2>
      <p class="mt-1 text-xs text-[var(--color-text-secondary)]">{diaActivo.estimulo}</p>
    </section>

    {diaActivo.bloques.map((bloque) => (
      <div class="mb-5">
        <h3 class="mb-2 px-1 text-[10px] font-semibold uppercase tracking-widest text-[var(--color-text-muted)]">
          {bloque.titulo}
        </h3>
        <ul class="space-y-2">
          {bloque.ejercicios.map((ex) => (
            <li class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-2)] p-4">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="text-sm font-semibold leading-snug">{ex.nombre}</div>
                  <div class="mt-0.5 text-[11px] text-[var(--color-text-muted)]">{ex.musculos}</div>
                </div>
                <div class="text-right">
                  <div class="text-sm font-bold tabular-nums">{ex.series}</div>
                  {ex.pesoEstimado && (
                    <div class="text-[10px] text-[var(--color-accent-warm)]">{ex.pesoEstimado}</div>
                  )}
                </div>
              </div>
              <p class="mt-3 text-xs leading-relaxed text-[var(--color-text-secondary)]">{ex.notas}</p>
              <div class="mt-3 flex flex-wrap items-center gap-1.5">
                <span class="rounded-md bg-[var(--color-bg)] px-2 py-0.5 text-[10px] text-[var(--color-text-muted)]">
                  Descanso {ex.descanso}
                </span>
                {ex.tecnicas.map((t) => (
                  <span class={`rounded-md px-2 py-0.5 text-[10px] font-medium ${TECNICA_COLORS[t]}`}>
                    {TECNICA_LABELS[t]}
                  </span>
                ))}
              </div>
              <ExerciseTracker client:load dia={diaActivo.code} ejercicioId={ex.id} />
            </li>
          ))}
        </ul>
      </div>
    ))}

    {diaActivo.notaFinal && (
      <aside class="mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-1)] p-4 text-xs leading-relaxed text-[var(--color-text-secondary)]">
        <strong class="text-[var(--color-text-primary)]">Descansos:</strong> {diaActivo.notaFinal}
      </aside>
    )}
  </AuthGuard>
</Layout>
